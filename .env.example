# =============================================================================
# Minimal setup - copy to `.env` and adjust secrets.
# Docker: `docker compose up` (frontend gets API_URL from compose; DB defaults below).
# Native dev: keep POSTGRES_* + API_URL for `make db` + `make dev` + `make dashboard`.
# =============================================================================

PROJECT_NAME=connexity

# Public URL of the app (no trailing slash). Use https://... in production.
SITE_URL=http://localhost:3000

# Auth & crypto - change in any shared or hosted environment
JWT_SECRET_KEY=changethis
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Placeholder below is invalid Fernet - integrations encrypt API keys and require a generated key.
ENCRYPTION_KEY=changethis

# Postgres - password is required. User/database match the DB container + backend.
POSTGRES_PASSWORD=password
POSTGRES_USER=postgres
POSTGRES_DB=app

# Host port when Postgres runs in Docker (native dev: backend uses POSTGRES_SERVER below)
POSTGRES_PORT=5433

# Native dev only - backend on host talks to Docker Postgres on localhost
POSTGRES_SERVER=localhost

# Native dev only - Next.js on host calls the API (Docker frontend uses http://backend:8000 from compose)
API_URL=http://localhost:8000

# MCP server - `make mcp` uses these.
# Public MCP transport is OAuth-protected and startup should fail if OAuth
# resource-server settings are missing.
# The MCP service forwards the authenticated user's MCP OAuth access token to
# the backend. Backend MCP actions are platform-scoped, but the user id from the
# token is used for audit fields.
# For self-hosted Claude connectors, the backend is the OAuth issuer.
# OAUTH_ISSUER_URL=https://your-backend.example.com
# Optional. Defaults to MCP_OAUTH_AUDIENCE when both services share one env file.
# OAUTH_DEFAULT_RESOURCE_URL=https://your-mcp.example.com/mcp
# CONNEXITY_API_URL=http://localhost:8000/api/v1
# MCP_HOST=0.0.0.0
# MCP_PORT=8001
# MCP_PATH=/mcp
# MCP_SERVER_NAME=connexity-mcp
# MCP_PUBLIC_BASE_URL=https://your-mcp.example.com
# MCP_OAUTH_ISSUER_URL=https://your-backend.example.com
# MCP_OAUTH_AUDIENCE=https://your-mcp.example.com/mcp
# Optional. Defaults to mcp:access.
# MCP_OAUTH_REQUIRED_SCOPES=mcp:access
# MCP_OAUTH_DISCOVERY_URL=
# MCP_OAUTH_JWKS_URL=
# MCP_OAUTH_RESOURCE_SERVER_URL=

# LLM providers - configure at least one key for simulators / judges / generators (choose the providers you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=
GOOGLE_API_KEY=

# Voice eval persona
# DEEPGRAM_API_KEY=
# ELEVENLABS_API_KEY=
# CARTESIA_API_KEY=

# Telephony — required for voice eval runs (Twilio caller + worker webhooks)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Voice simulation (VOICE_DEPLOYMENT_MODE defaults to off; set local|kubernetes in compose/k8s)
# VOICE_MAX_CONCURRENCY=5
# VOICE_DEFAULT_CALL_DURATION_SECONDS=300
# VOICE_MAX_CALL_DURATION_SECONDS=3600
# VOICE_DEFAULT_TIMEOUT_PER_TEST_CASE_MS=600000
# VOICE_PUBLIC_BASE_URL=


# =============================================================================
# Docker images - defaults match GHCR packages published from this repo.
# Forks: set these to your owner/repo or build locally with docker-compose.build.yml
# =============================================================================
# CONNEXITY_BACKEND_IMAGE=ghcr.io/connexity-ai/connexity-backend:latest
# CONNEXITY_FRONTEND_IMAGE=ghcr.io/connexity-ai/connexity-frontend:latest
# CONNEXITY_MCP_SERVER_IMAGE=ghcr.io/connexity-ai/connexity-mcp-server:latest

# =============================================================================
# Advanced / optional (uncomment to override)
# =============================================================================

# ENVIRONMENT=local

# FIRST_SUPERUSER=admin@example.com
# FIRST_SUPERUSER_PASSWORD=password

# Whitelisted browser origins (SITE_URL is always allowed too)
# BACKEND_CORS_ORIGINS=http://localhost,https://localhost,http://localhost:3000,https://localhost:3000

# ACCESS_TOKEN_EXPIRE_HOURS=168

# External DB (e.g. Neon) - do not set POSTGRES_* for the app if using this
# DATABASE_URL=

# CLI - public API base URL when using connexity-cli from your machine
# CONNEXITY_CLI_API_URL=http://localhost:8000
# CONNEXITY_CLI_API_TOKEN=

# LLM defaults and retries
# LLM_DEFAULT_MODEL=gpt-4.1
# LLM_DEFAULT_PROVIDER=openai
# LLM_RETRY_MAX_ATTEMPTS=5
# LLM_RETRY_MIN_WAIT_SECONDS=1
# LLM_RETRY_MAX_WAIT_SECONDS=60
# GENERATOR_CUSTOM_METRIC_DEFAULT_WEIGHT=0.15

# Optional defaults for voice eval persona (STT/TTS pickers)
# DEFAULT_STT_PROVIDER=deepgram
# DEFAULT_STT_MODEL=nova-3-general
# DEFAULT_TTS_PROVIDER=deepgram
# DEFAULT_TTS_MODEL=aura
# DEFAULT_TTS_VOICE_ID=aura-2-helena-en
