{
  "packages": {
    "backend/cli": {
      "release-type": "simple",
      "package-name": "connexity-cli",
      "component": "cli",
      "include-component-in-tag": true,
      "tag-separator": "-",
      "include-paths": ["backend/cli", "pyproject.toml"],
      "extra-files": [
        {
          "type": "generic",
          "path": "**/pyproject.toml",
          "glob": true
        }
      ],
      "changelog-path": "CHANGELOG.md",
      "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "perf", "section": "Performance" },
        { "type": "docs", "section": "Documentation" }
      ]
    }
  }
}
