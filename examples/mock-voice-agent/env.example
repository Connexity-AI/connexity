# Copy to repo root `.env` or export before running (see README).

# Twilio — same account Connexity voice worker uses to dial your agent number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Public HTTPS origin for this process (ngrok/Cloudflare tunnel), no trailing slash.
# Twilio webhooks and Connexity recording URLs must reach this host.
MOCK_VOICE_AGENT_PUBLIC_BASE_URL=https://your-tunnel.example

# Speech providers (Deepgram STT + OpenAI LLM + ElevenLabs TTS)
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Connexity backend — bearer token from login (see README)
CONNEXITY_API_URL=http://localhost:8000
CONNEXITY_API_TOKEN=

# Optional overrides
# MOCK_VOICE_AGENT_HTTP_HOST=0.0.0.0
# MOCK_VOICE_AGENT_HTTP_PORT=8766
# MOCK_VOICE_LLM_MODEL=gpt-4.1-mini
# MOCK_VOICE_DEEPGRAM_STT_MODEL=nova-3-general
# MOCK_VOICE_ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
# MOCK_VOICE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
